{
  "name": "campaign-kit-templates",
  "version": "1.0.0",
  "description": "Starter templates for next-campaign-page-kit (SDK 0.4.x)",
  "scripts": {
    "setup": "npx campaign-init",
    "start": "npx campaign-start",
    "dev": "npx campaign-dev",
    "build": "npx campaign-build",
    "clone": "npx campaign-clone",
    "config": "npx campaign-config",
    "compress": "npx campaign-compress",
    "compress:preview": "npx campaign-compress --preview",
    "css:build:landing": "tailwindcss -c ./tailwind.config.js -i ./tailwind.input.css -o ./src/landing/assets/css/tailwind.css --content './src/landing/**/*.html' --minify",
    "css:build:presell-1": "tailwindcss -c ./tailwind.config.js -i ./tailwind.input.css -o ./src/presell-1/assets/css/tailwind.css --content './src/presell-1/**/*.html' --minify",
    "css:build": "npm run css:build:landing && npm run css:build:presell-1"
  },
  "dependencies": {
    "next-campaign-page-kit": "^0.0.9"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.19"
  }
}
